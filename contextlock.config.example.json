{
  "schemaVersion": 1,
  "blockedPatterns": [
    ".env",
    ".env.*",
    "**/.env",
    "**/.env.*",
    "**/*.pem",
    "**/*.key",
    "**/id_rsa",
    "**/id_dsa",
    "**/credentials.json",
    "**/service-account*.json",
    "**/*.sqlite",
    "**/*.db",
    "**/*.dump",
    "**/node_modules/**",
    "**/.git/**",
    "**/dist/**",
    "**/build/**",
    "build/**",
    "**/.next/**",
    "**/.turbo/**",
    "**/.gradle/**",
    "**/.idea/**",
    "**/.kotlin/**",
    "**/capture/**",
    "**/capture.{png,jpg,jpeg,webp,gif,bmp,tif,tiff,heic,avif}",
    "**/captures/**",
    "**/screenshot/**",
    "**/screenshot.{png,jpg,jpeg,webp,gif,bmp,tif,tiff,heic,avif}",
    "**/screenshots/**",
    "**/*.apk",
    "**/*.aab",
    "**/*.ipa",
    "**/*.keystore",
    "**/*.jks",
    "**/*.tflite",
    "**/*.onnx",
    "**/*.mlmodel"
  ],
  "redact": {
    "apiKeys": true,
    "jwt": true,
    "databaseUrls": true,
    "privateKeys": true,
    "webhooks": true,
    "emails": false
  }
}
