{
  "name": "contextlock",
  "version": "0.1.0",
  "description": "Local-first MCP safety layer that blocks and redacts risky repo context before AI agents see it.",
  "type": "module",
  "exports": {},
  "packageManager": "pnpm@11.7.0",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/LutaElbert/contextlock.git"
  },
  "bin": {
    "contextlock": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "assets/social-preview.jpg",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "scan": "tsx src/cli.ts scan",
    "mcp": "tsx src/cli.ts mcp",
    "test:skill": "tsx tests/skill-smoke.ts",
    "test:mcp": "pnpm build && tsx tests/mcp-smoke.ts",
    "test:scanner": "tsx tests/scanner.test.ts",
    "test:policy": "tsx tests/policy.test.ts",
    "test:cli": "pnpm build && tsx tests/cli-smoke.ts",
    "test:package": "tsx tests/package-smoke.ts",
    "test": "pnpm typecheck && pnpm test:scanner && pnpm test:policy && pnpm test:cli && pnpm test:skill && pnpm test:mcp && pnpm test:package",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm build"
  },
  "keywords": [
    "mcp",
    "ai",
    "security",
    "secrets",
    "redaction",
    "vibe-coding"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "picomatch": "^4.0.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "@types/picomatch": "^4.0.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.13"
  }
}
